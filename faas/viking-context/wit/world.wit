package tachyon:ai@1.0.0;

// Provided by the Tachyon-Mesh host runtime.
// Will migrate to tachyon:mesh package once the mesh WIT is published.
interface storage-broker {
    /// Metadata returned by stat-file, used for cache-key construction.
    record file-stat {
        size-bytes: u64,
        /// Unix timestamp (seconds). Used to detect file changes and
        /// invalidate the corresponding kv-partition cache entry.
        modified-secs: u64,
    }

    /// Read raw bytes from an absolute or repo-relative file path.
    read-file: func(path: string) -> result<list<u8>, string>;

    /// Return lightweight metadata without reading the full file.
    /// Used to build the mtime-based cache key before deciding whether
    /// a kv-partition lookup is worthwhile.
    stat-file: func(path: string) -> result<file-stat, string>;
}

/// Persistent key-value partition provided by the Tachyon-Mesh host.
/// Configured in the deployment manifest as disk-backed or memory-only.
/// Handles concurrent access and I/O queuing — the component never
/// touches the underlying storage format directly.
interface kv-partition {
    /// Retrieve a previously stored value. Returns `none` on cache miss.
    get: func(key: string) -> result<option<list<u8>>, string>;

    /// Persist a value. Overwrites any existing entry for the same key.
    set: func(key: string, value: list<u8>) -> result<_, string>;

    /// Remove a single entry. No-op if the key does not exist.
    delete: func(key: string) -> result<_, string>;
}

/// Hierarchical code-context interface consumed by the Pulsar agent.
interface viking-context {
    /// Depth of the semantic context requested.
    enum context-level {
        /// High-level file summary — lowest token cost.
        l0-summary,
        /// AST skeleton (signatures, structs, traits) — no bodies.
        l1-structure,
        /// Exact source code — highest token cost.
        l2-raw,
    }

    /// A resolved chunk of context ready for LLM prompt injection.
    record context-response {
        /// The URI that was resolved.
        uri: string,
        /// The actual level resolved (may differ from request if fallback occurred).
        level: context-level,
        /// The text payload to inject into the prompt.
        payload: string,
        /// Rough token estimate (chars / 4) to help the agent manage its budget.
        token-estimate: u32,
    }

    /// Resolve a viking:// URI into a structured, token-efficient payload.
    resolve: func(uri: string, level: context-level) -> result<context-response, string>;
}

world viking-context-world {
    import storage-broker;
    import kv-partition;
    export viking-context;
}
